{
  "compilerOptions": {
    "strict": true,
    "target": "ES2017",
    "lib": ["ES2024", "DOM"],
    "jsx": "react-jsx",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "outDir": "../dist/spa"
  },
  "include": [
    "./src",
    "./build"
  ],
  "exclude": [
    "node_modules"
  ]
}
