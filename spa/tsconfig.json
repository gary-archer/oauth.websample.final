{
  "compilerOptions": {
    "strict": true,
    "target": "ES2017",
    "lib": ["ES2025", "DOM"],
    "jsx": "react-jsx",
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "sourceMap": true,
    "rootDir": "src"
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules"
  ]
}
