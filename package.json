  },
  "dependencies": {
    "js-event-bus": "^1.1.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-modal": "^3.16.3",
    "react-router-dom": "^7.17.0",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/react-modal": "^3.16.3",
    "eslint": "^10.5.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "workspaces": [
    "build",
